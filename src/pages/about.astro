---
import ShopLayout from '../layouts/ShopLayout.astro';
---

<ShopLayout title="About Us - ShopWise">
  <main class="main">

    <!-- Hero Header -->
    <div class="about-hero position-relative py-5 text-white" style="background: linear-gradient(rgba(15, 23, 42, 0.75), rgba(30, 41, 59, 0.85)), url('/shop/assets/img/product/product-showcase-2.webp') no-repeat center center / cover; min-height: 400px; display: flex; align-items: center;">
      <div class="container text-center py-5">
        <span class="badge bg-primary text-uppercase px-3 py-2 mb-3" style="letter-spacing: 1px;">OUR STORY</span>
        <h1 class="display-3 fw-bold mb-3">About ShopWise</h1>
        <p class="lead mx-auto text-light" style="max-width: 650px;">We craft premium lifestyle, home, and utility collections that combine modern aesthetics with everyday functionality.</p>
      </div>
    </div>

    <!-- Company Stats -->
    <section class="py-5 bg-white border-bottom">
      <div class="container">
        <div class="row text-center g-4">
          <div class="col-md-3 col-6">
            <h2 class="display-5 fw-bold text-primary mb-1">10K+</h2>
            <p class="text-muted mb-0 fw-semibold">Happy Customers</p>
          </div>
          <div class="col-md-3 col-6">
            <h2 class="display-5 fw-bold text-primary mb-1">45K+</h2>
            <p class="text-muted mb-0 fw-semibold">Orders Completed</p>
          </div>
          <div class="col-md-3 col-6">
            <h2 class="display-5 fw-bold text-primary mb-1">20+</h2>
            <p class="text-muted mb-0 fw-semibold">Partner Brands</p>
          </div>
          <div class="col-md-3 col-6">
            <h2 class="display-5 fw-bold text-primary mb-1">99.8%</h2>
            <p class="text-muted mb-0 fw-semibold">Positive Feedback</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Content Section -->
    <section class="py-5 my-3 bg-light">
      <div class="container py-4">
        <div class="row align-items-center g-5">
          <div class="col-lg-6">
            <div class="position-relative">
              <img src="/shop/assets/img/product/product-showcase-1.webp" alt="Design studio" class="img-fluid rounded-4 shadow-lg w-100 object-fit-cover" style="max-height: 450px;">
              <div class="position-absolute bottom-0 end-0 bg-primary text-white p-4 m-3 rounded-3 shadow-md d-none d-sm-block" style="max-width: 250px;">
                <h5 class="fw-bold mb-2">Designed for life</h5>
                <p class="small mb-0 opacity-75">Every item is crafted with premium materials and absolute attention to detail.</p>
              </div>
            </div>
          </div>
          <div class="col-lg-6">
            <span class="text-primary fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 1px;">OUR MISSION</span>
            <h2 class="fw-bold mb-4 mt-2 display-6">Excellence in every single detail.</h2>
            <p class="text-muted mb-4 lead" style="font-size: 1.1rem;">Founded in 2026, ShopWise was born from a simple idea: that everyday home, tech, and kitchen products don't have to be boring or overpriced. We partner directly with manufacturers to bring you curated premium items that stand the test of time.</p>
            
            <div class="row g-4 mt-2">
              <div class="col-sm-6">
                <div class="d-flex align-items-start gap-3">
                  <div class="btn btn-primary btn-sm rounded-3 py-2 px-2.5 d-flex align-items-center justify-content-center">
                    <i class="bi bi-shield-check text-white" style="font-size: 1.25rem;"></i>
                  </div>
                  <div>
                    <h5 class="fw-bold mb-1" style="font-size: 1rem;">Quality Guarantee</h5>
                    <p class="small text-muted mb-0">Double checked quality controls on every single order.</p>
                  </div>
                </div>
              </div>

              <div class="col-sm-6">
                <div class="d-flex align-items-start gap-3">
                  <div class="btn btn-primary btn-sm rounded-3 py-2 px-2.5 d-flex align-items-center justify-content-center">
                    <i class="bi bi-truck text-white" style="font-size: 1.25rem;"></i>
                  </div>
                  <div>
                    <h5 class="fw-bold mb-1" style="font-size: 1rem;">Fast & Free Shipping</h5>
                    <p class="small text-muted mb-0">Complimentary delivery straight to your doorstep.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Company Values -->
    <section class="py-5 bg-white">
      <div class="container py-4 text-center">
        <span class="text-primary fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 1px;">OUR VALUES</span>
        <h2 class="fw-bold display-6 mb-5 mt-2">Built on Trust, Fueled by Innovation</h2>
        
        <div class="row g-4 text-start">
          <div class="col-lg-4">
            <div class="card border-0 p-4 rounded-4 bg-light h-100">
              <div class="mb-3 text-primary"><i class="bi bi-heart-fill" style="font-size: 2.5rem;"></i></div>
              <h4 class="fw-bold mb-3">Customer First</h4>
              <p class="text-muted">We put you first in everything we do. Our support is available 24/7, and we offer a hassle-free 30-day return policy to ensure absolute peace of mind.</p>
            </div>
          </div>

          <div class="col-lg-4">
            <div class="card border-0 p-4 rounded-4 bg-light h-100">
              <div class="mb-3 text-primary"><i class="bi bi-tree-fill" style="font-size: 2.5rem;"></i></div>
              <h4 class="fw-bold mb-3">Sustainability</h4>
              <p class="text-muted">We source materials ethically and design recyclable packaging to minimize our environmental footprint while maintaining product resilience.</p>
            </div>
          </div>

          <div class="col-lg-4">
            <div class="card border-0 p-4 rounded-4 bg-light h-100">
              <div class="mb-3 text-primary"><i class="bi bi-stars" style="font-size: 2.5rem;"></i></div>
              <h4 class="fw-bold mb-3">Design Integrity</h4>
              <p class="text-muted">No generic templates or cheap alternatives. Our design team iterates on every collection to produce beautiful, durable, and highly functional assets.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</ShopLayout>
