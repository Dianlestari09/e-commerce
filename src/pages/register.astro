---
import ShopLayout from '../layouts/ShopLayout.astro';
---

<ShopLayout title="Register - ShopWise">
  <main class="main my-5">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
          <div class="card border-0 shadow-lg p-4 bg-white rounded-4">
            <div class="text-center mb-4">
              <h2 class="fw-bold text-dark mb-1">Create Account</h2>
              <p class="text-muted">Register to start shopping and tracking your orders</p>
            </div>

            <div id="alert-container"></div>

            <form id="register-form">
              <div class="row">
                <div class="col-md-6 mb-3">
                  <label for="fullName" class="form-label fw-semibold">Full Name</label>
                  <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-person"></i></span>
                    <input type="text" class="form-control bg-light border-start-0" id="fullName" required placeholder="John Doe">
                  </div>
                </div>

                <div class="col-md-6 mb-3">
                  <label for="phone" class="form-label fw-semibold">Phone Number</label>
                  <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-telephone"></i></span>
                    <input type="tel" class="form-control bg-light border-start-0" id="phone" placeholder="08123456789">
                  </div>
                </div>
              </div>

              <div class="mb-3">
                <label for="email" class="form-label fw-semibold">Email Address</label>
                <div class="input-group">
                  <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-envelope"></i></span>
                  <input type="email" class="form-control bg-light border-start-0" id="email" required placeholder="name@example.com">
                </div>
              </div>

              <div class="mb-3">
                <label for="password" class="form-label fw-semibold">Password</label>
                <div class="input-group">
                  <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-lock"></i></span>
                  <input type="password" class="form-control bg-light border-start-0" id="password" required placeholder="••••••••" minlength="6">
                </div>
              </div>

              <div class="mb-4">
                <label for="address" class="form-label fw-semibold">Shipping Address</label>
                <div class="input-group">
                  <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-geo-alt"></i></span>
                  <textarea class="form-control bg-light border-start-0" id="address" rows="2" placeholder="Jl. Raya No. 123, Jakarta"></textarea>
                </div>
              </div>

              <button type="submit" class="btn btn-primary w-100 py-2.5 fw-bold rounded-3" id="submit-btn">
                <span id="btn-text">Register Account</span>
                <span id="btn-spinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
              </button>
            </form>

            <div class="text-center mt-4">
              <p class="text-muted mb-0">Already have an account? <a href="/login" class="text-primary fw-bold text-decoration-none">Log In here</a></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</ShopLayout>

<script>
  import { supabase } from '../lib/supabase';

  const registerForm = document.getElementById('register-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLElement;
  const btnSpinner = document.getElementById('btn-spinner') as HTMLElement;
  const alertContainer = document.getElementById('alert-container') as HTMLElement;

  function showAlert(message: string, type: 'danger' | 'success') {
    alertContainer.innerHTML = `
      <div class="alert alert-${type} alert-dismissible fade show border-0 rounded-3" role="alert">
        <i class="bi ${type === 'danger' ? 'bi-exclamation-triangle-fill' : 'bi-check-circle-fill'} me-2"></i>
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    `;
  }

  registerForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // UI state loading
    if (submitBtn) submitBtn.disabled = true;
    btnText?.classList.add('d-none');
    btnSpinner?.classList.remove('d-none');
    alertContainer.innerHTML = '';

    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const fullName = (document.getElementById('fullName') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('phone') as HTMLInputElement).value.trim();
    const address = (document.getElementById('address') as HTMLTextAreaElement).value.trim();

    try {
      const { data, error } = await supabase.auth.signUp({
        email,
        password,
        options: {
          data: {
            full_name: fullName,
            phone: phone,
            shipping_address: address,
            role: 'customer'
          }
        }
      });

      if (error) {
        showAlert(error.message, 'danger');
        if (submitBtn) submitBtn.disabled = false;
        btnText?.classList.remove('d-none');
        btnSpinner?.classList.add('d-none');
        return;
      }

      // Check if email confirmation is required (session might be null if confirmation is active)
      if (data.user && !data.session) {
        showAlert('Registration successful! Please check your email to verify your account.', 'success');
      } else {
        showAlert('Registration successful! Logged in automatically. Redirecting...', 'success');
        setTimeout(() => {
          window.location.href = '/';
        }, 1500);
      }
    } catch (err: any) {
      console.error(err);
      showAlert('An unexpected error occurred during registration.', 'danger');
      if (submitBtn) submitBtn.disabled = false;
      btnText?.classList.remove('d-none');
      btnSpinner?.classList.add('d-none');
    }
  });
</script>

<style>
  .btn-primary {
    background-color: var(--accent-color, #ff6f61);
    border-color: var(--accent-color, #ff6f61);
    transition: all 0.3s ease;
  }
  .btn-primary:hover {
    background-color: #e55e51;
    border-color: #e55e51;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 111, 97, 0.2);
  }
  .form-control:focus, .form-select:focus {
    border-color: var(--accent-color, #ff6f61);
    box-shadow: 0 0 0 0.25rem rgba(255, 111, 97, 0.15);
  }
</style>
