---
import ShopLayout from '../../layouts/ShopLayout.astro';
import { supabase } from '../../lib/supabase';

// Fetch published articles
let articles: any[] = [];
let categories: string[] = [];

try {
  const { data } = await supabase
    .from('articles')
    .select('id, title, slug, excerpt, cover_image, author_name, category, tags, published_at, created_at')
    .eq('status', 'published')
    .order('published_at', { ascending: false });

  if (data) {
    articles = data;
    // Get unique categories
    const catSet = new Set<string>(data.map((a: any) => a.category).filter(Boolean));
    categories = Array.from(catSet);
  }
} catch (e) {
  console.error('Failed to load articles:', e);
}

function formatDate(dateStr: string | null) {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('id-ID', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
}

function readingTime(text: string | null) {
  if (!text) return '1 min';
  const words = text.replace(/<[^>]+>/g, '').split(/\s+/).length;
  const mins = Math.max(1, Math.ceil(words / 200));
  return `${mins} min read`;
}

const categoryLabels: Record<string, string> = {
  tips: 'Tips & Tricks',
  review: 'Product Review',
  news: 'News',
  inspirasi: 'Inspirasi',
  promo: 'Promo & Deals',
  tutorial: 'Tutorial'
};

// SEO for list page
const pageTitle = 'Blog & Artikel - ShopWise';
const pageDesc = 'Temukan tips belanja cerdas, review produk terbaru, inspirasi dekorasi rumah, dan panduan gaya hidup dari tim ShopWise.';
const canonicalUrl = `${Astro.url.origin}/articles`;

// JSON-LD ItemList schema
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "ShopWise Blog & Artikel",
  "description": pageDesc,
  "url": canonicalUrl,
  "numberOfItems": articles.length,
  "itemListElement": articles.slice(0, 10).map((a, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${Astro.url.origin}/articles/${a.slug}`,
    "name": a.title
  }))
};
---

<ShopLayout title={pageTitle} description={pageDesc}>
  <!-- SEO Extras injected in head via slot -->
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl}>
    <meta property="og:type" content="website">
    <meta property="og:title" content={pageTitle}>
    <meta property="og:description" content={pageDesc}>
    <meta property="og:url" content={canonicalUrl}>
    {articles[0]?.cover_image && <meta property="og:image" content={articles[0].cover_image}>}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={pageTitle}>
    <meta name="twitter:description" content={pageDesc}>
    {articles[0]?.cover_image && <meta name="twitter:image" content={articles[0].cover_image}>}
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)}></script>
  </Fragment>

  <main class="main">

    <!-- Hero Section -->
    <section class="articles-hero py-5 text-white" style="background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #0f172a 100%); min-height: 320px; display: flex; align-items: center;">
      <div class="container text-center py-4">
        <span class="badge px-3 py-2 mb-3 text-uppercase" style="background: rgba(255,255,255,0.15); letter-spacing: 1.5px; font-size: 0.75rem;">Blog & Artikel</span>
        <h1 class="display-4 fw-bold mb-3">Insights, Tips & Inspirasi</h1>
        <p class="lead text-light mx-auto" style="max-width: 600px; opacity: 0.85;">
          Panduan belanja cerdas, review produk jujur, dan inspirasi gaya hidup dari tim ShopWise.
        </p>
      </div>
    </section>

    <!-- Filter & Article Grid -->
    <section class="py-5">
      <div class="container">

        <!-- Category Filter -->
        {categories.length > 0 && (
          <div class="d-flex flex-wrap gap-2 mb-5 justify-content-center" id="category-filters">
            <button class="btn btn-primary btn-sm rounded-pill px-4 filter-btn active" data-cat="all">
              All Articles
            </button>
            {categories.map(cat => (
              <button class="btn btn-outline-secondary btn-sm rounded-pill px-4 filter-btn" data-cat={cat}>
                {categoryLabels[cat] || cat}
              </button>
            ))}
          </div>
        )}

        {articles.length === 0 ? (
          <div class="text-center py-5">
            <i class="bi bi-newspaper text-muted" style="font-size: 4rem; opacity: 0.3;"></i>
            <h3 class="mt-4 text-muted">Belum ada artikel yang dipublikasikan</h3>
            <p class="text-muted">Nantikan konten menarik dari tim ShopWise.</p>
          </div>
        ) : (
          <>
            {/* Featured Article (first one) */}
            {articles.length > 0 && (
              <div class="mb-5 article-card" data-cat={articles[0].category}>
                <a href={`/articles/${articles[0].slug}`} class="text-decoration-none">
                  <div class="card border-0 shadow-sm overflow-hidden rounded-4 article-featured-card">
                    <div class="row g-0 align-items-stretch">
                      <div class="col-lg-6">
                        <div class="position-relative h-100" style="min-height: 320px;">
                          <img
                            src={articles[0].cover_image || '/shop/assets/img/product/product-default.webp'}
                            alt={articles[0].title}
                            class="img-fluid w-100 h-100 object-fit-cover"
                            style="object-fit: cover;"
                            loading="eager"
                          >
                          <div class="position-absolute top-0 start-0 m-3">
                            <span class="badge text-white text-capitalize px-3 py-2" style="background: rgba(13,110,253,0.9); font-size: 0.75rem;">
                              {categoryLabels[articles[0].category] || articles[0].category}
                            </span>
                          </div>
                        </div>
                      </div>
                      <div class="col-lg-6 d-flex flex-column">
                        <div class="card-body p-4 p-lg-5 d-flex flex-column">
                          <div class="mb-3">
                            <span class="badge bg-warning text-dark px-3 py-1 rounded-pill small">✨ Featured</span>
                          </div>
                          <h2 class="fw-bold mb-3 text-dark lh-sm" style="font-size: 1.5rem;">{articles[0].title}</h2>
                          <p class="text-muted mb-4 flex-grow-1" style="line-height: 1.7;">{articles[0].excerpt}</p>
                          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-auto">
                            <div class="d-flex align-items-center gap-2 text-muted small">
                              <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white" style="width: 32px; height: 32px; font-size: 0.75rem; font-weight: 600; flex-shrink: 0;">
                                {(articles[0].author_name || 'D').charAt(0).toUpperCase()}
                              </div>
                              <div>
                                <div class="fw-semibold text-dark" style="font-size: 0.85rem;">{articles[0].author_name || 'Dian Lestari Kurniawati'}</div>
                                <div style="font-size: 0.75rem;">{formatDate(articles[0].published_at)}</div>
                              </div>
                            </div>
                            <span class="btn btn-primary btn-sm rounded-pill px-4">
                              Baca <i class="bi bi-arrow-right ms-1"></i>
                            </span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </a>
              </div>
            )}

            {/* Article Grid (rest of articles) */}
            {articles.length > 1 && (
              <div class="row g-4" id="articles-grid">
                {articles.slice(1).map(article => (
                  <div class="col-md-6 col-lg-4 article-card" data-cat={article.category}>
                    <a href={`/articles/${article.slug}`} class="text-decoration-none h-100 d-block">
                      <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden article-grid-card">
                        <div class="position-relative" style="height: 220px; overflow: hidden;">
                          <img
                            src={article.cover_image || '/shop/assets/img/product/product-default.webp'}
                            alt={article.title}
                            class="img-fluid w-100 h-100 article-thumb"
                            style="object-fit: cover; transition: transform 0.4s ease;"
                            loading="lazy"
                          >
                          <div class="position-absolute top-0 start-0 m-3">
                            <span class="badge text-white text-capitalize px-3 py-1" style="background: rgba(0,0,0,0.6); font-size: 0.7rem; backdrop-filter: blur(4px);">
                              {categoryLabels[article.category] || article.category}
                            </span>
                          </div>
                        </div>
                        <div class="card-body p-4 d-flex flex-column">
                          <h3 class="fw-bold text-dark mb-2 lh-sm" style="font-size: 1.05rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            {article.title}
                          </h3>
                          <p class="text-muted small mb-3 flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.6;">
                            {article.excerpt}
                          </p>
                          <div class="d-flex align-items-center justify-content-between mt-auto pt-3 border-top">
                            <div class="text-muted" style="font-size: 0.78rem;">
                              <i class="bi bi-calendar3 me-1"></i>{formatDate(article.published_at)}
                            </div>
                            <div class="text-primary fw-semibold small">
                              Baca <i class="bi bi-arrow-right"></i>
                            </div>
                          </div>
                        </div>
                      </div>
                    </a>
                  </div>
                ))}
              </div>
            )}
          </>
        )}
      </div>
    </section>

  </main>

  <style>
    .articles-hero {
      background-attachment: fixed;
    }
    .article-featured-card {
      transition: box-shadow 0.3s ease, transform 0.3s ease;
    }
    .article-featured-card:hover {
      box-shadow: 0 20px 40px rgba(0,0,0,0.12) !important;
      transform: translateY(-2px);
    }
    .article-grid-card:hover .article-thumb {
      transform: scale(1.05);
    }
    .article-grid-card {
      transition: box-shadow 0.3s ease, transform 0.3s ease;
    }
    .article-grid-card:hover {
      box-shadow: 0 12px 30px rgba(0,0,0,0.1) !important;
      transform: translateY(-4px);
    }
    .filter-btn.active {
      background-color: var(--bs-primary) !important;
      border-color: var(--bs-primary) !important;
      color: white !important;
    }
    .article-card {
      transition: opacity 0.3s ease;
    }
    .article-card.hidden {
      display: none !important;
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const articleCards = document.querySelectorAll('.article-card');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', function () {
          const cat = this.dataset.cat;
          filterBtns.forEach(b => b.classList.remove('active'));
          this.classList.add('active');

          articleCards.forEach(card => {
            if (cat === 'all' || card.dataset.cat === cat) {
              card.classList.remove('hidden');
            } else {
              card.classList.add('hidden');
            }
          });
        });
      });
    });
  </script>
</ShopLayout>
