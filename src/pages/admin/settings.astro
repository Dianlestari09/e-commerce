---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Web Settings - EasyAdmin">
  <div
    class="page-header d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4"
  >
    <div>
      <h1 class="page-title h3 mb-1 font-weight-bold">Web Settings</h1>
      <p class="text-muted mb-0">
        Manage all visual and text content displayed on the main website
        storefront.
      </p>
    </div>
  </div>

  <div class="card border-0 shadow-sm p-4 bg-white">
    <div id="alert-container"></div>

    <!-- Navigation Tabs -->
    <ul
      class="nav nav-tabs nav-tabs-buffered mb-4"
      id="settingsTabs"
      role="tablist"
    >
      <li class="nav-item" role="presentation">
        <button
          class="nav-link active fw-semibold"
          id="hero-tab"
          data-bs-toggle="tab"
          data-bs-target="#hero-panel"
          type="button"
          role="tab"
          aria-controls="hero-panel"
          aria-selected="true"
        >
          <i class="bi bi-window-sidebar me-2"></i>Hero Section
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button
          class="nav-link fw-semibold"
          id="promo-tab"
          data-bs-toggle="tab"
          data-bs-target="#promo-panel"
          type="button"
          role="tab"
          aria-controls="promo-panel"
          aria-selected="false"
        >
          <i class="bi bi-tag me-2"></i>Promo Section
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button
          class="nav-link fw-semibold"
          id="layout-tab"
          data-bs-toggle="tab"
          data-bs-target="#layout-panel"
          type="button"
          role="tab"
          aria-controls="layout-panel"
          aria-selected="false"
        >
          <i class="bi bi-layout-text-window-reverse me-2"></i>Header, Footer &
          Info
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button
          class="nav-link fw-semibold"
          id="shipping-tab"
          data-bs-toggle="tab"
          data-bs-target="#shipping-panel"
          type="button"
          role="tab"
          aria-controls="shipping-panel"
          aria-selected="false"
        >
          <i class="bi bi-truck me-2"></i>Shipping Rates
        </button>
      </li>
    </ul>

    <!-- Tabs Content Form -->
    <form id="settings-form">
      <div class="tab-content" id="settingsTabsContent">
        <!-- 1. HERO SECTION TAB -->
        <div
          class="tab-pane fade show active"
          id="hero-panel"
          role="tabpanel"
          aria-labelledby="hero-tab"
        >
          <h5 class="fw-bold mb-3 text-dark border-bottom pb-2">
            Hero Intro Content
          </h5>
          <div class="row g-3 mb-4">
            <div class="col-md-6">
              <label for="hero-badge" class="form-label fw-semibold"
                >Intro Badge Label</label
              >
              <input
                type="text"
                class="form-control"
                id="hero-badge"
                required
                placeholder="e.g. Curated Selection"
              />
            </div>
            <div class="col-md-6">
              <label for="hero-title" class="form-label fw-semibold"
                >Headline / Title</label
              >
              <input
                type="text"
                class="form-control"
                id="hero-title"
                required
                placeholder="e.g. Discover What Defines Modern Living"
              />
            </div>
            <div class="col-12">
              <label for="hero-subtext" class="form-label fw-semibold"
                >Intro Subtext / Paragraph</label
              >
              <textarea
                class="form-control"
                id="hero-subtext"
                rows="3"
                required
                placeholder="Describe the shop or introductory message..."
              ></textarea>
            </div>
            <div class="col-md-3">
              <label for="hero-btn1-text" class="form-label fw-semibold"
                >Primary Button Text</label
              >
              <input
                type="text"
                class="form-control"
                id="hero-btn1-text"
                required
                placeholder="Browse Items"
              />
            </div>
            <div class="col-md-3">
              <label for="hero-btn1-link" class="form-label fw-semibold"
                >Primary Button Link</label
              >
              <input
                type="text"
                class="form-control"
                id="hero-btn1-link"
                required
                placeholder="/category"
              />
            </div>
            <div class="col-md-3">
              <label for="hero-btn2-text" class="form-label fw-semibold"
                >Secondary Button Text</label
              >
              <input
                type="text"
                class="form-control"
                id="hero-btn2-text"
                required
                placeholder="See All Categories"
              />
            </div>
            <div class="col-md-3">
              <label for="hero-btn2-link" class="form-label fw-semibold"
                >Secondary Button Link</label
              >
              <input
                type="text"
                class="form-control"
                id="hero-btn2-link"
                required
                placeholder="/category"
              />
            </div>
          </div>

          <h5 class="fw-bold mb-3 text-dark border-bottom pb-2 mt-4">
            Hero Side Product Tiles
          </h5>

          <!-- Product Tile 1 -->
          <div class="card bg-light border-0 p-3 mb-3">
            <h6 class="fw-bold text-primary mb-2">
              <i class="bi bi-1-circle-fill me-2"></i>Product Tile 1 (Best
              Seller)
            </h6>
            <div class="row g-3">
              <div class="col-md-3">
                <label for="tile1-badge" class="form-label small fw-semibold"
                  >Tile Badge</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="tile1-badge"
                  placeholder="Best Seller"
                />
              </div>
              <div class="col-md-3">
                <label for="tile1-name" class="form-label small fw-semibold"
                  >Product Name</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="tile1-name"
                  required
                />
              </div>
              <div class="col-md-2">
                <label for="tile1-price" class="form-label small fw-semibold"
                  >Current Price ($)</label
                >
                <input
                  type="number"
                  step="0.01"
                  class="form-control form-control-sm"
                  id="tile1-price"
                  required
                />
              </div>
              <div class="col-md-2">
                <label for="tile1-original" class="form-label small fw-semibold"
                  >Original Price ($)</label
                >
                <input
                  type="number"
                  step="0.01"
                  class="form-control form-control-sm"
                  id="tile1-original"
                />
              </div>
              <div class="col-md-2">
                <label for="tile1-image" class="form-label small fw-semibold"
                  >Image path / URL</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="tile1-image"
                  required
                />
              </div>
            </div>
          </div>

          <!-- Product Tile 2 -->
          <div class="card bg-light border-0 p-3 mb-3">
            <h6 class="fw-bold text-primary mb-2">
              <i class="bi bi-2-circle-fill me-2"></i>Product Tile 2 (Trending)
            </h6>
            <div class="row g-3">
              <div class="col-md-3">
                <label for="tile2-badge" class="form-label small fw-semibold"
                  >Tile Badge</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="tile2-badge"
                  placeholder="Trending Now"
                />
              </div>
              <div class="col-md-3">
                <label for="tile2-name" class="form-label small fw-semibold"
                  >Product Name</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="tile2-name"
                  required
                />
              </div>
              <div class="col-md-2">
                <label for="tile2-price" class="form-label small fw-semibold"
                  >Current Price ($)</label
                >
                <input
                  type="number"
                  step="0.01"
                  class="form-control form-control-sm"
                  id="tile2-price"
                  required
                />
              </div>
              <div class="col-md-2">
                <label for="tile2-original" class="form-label small fw-semibold"
                  >Original Price ($)</label
                >
                <input
                  type="number"
                  step="0.01"
                  class="form-control form-control-sm"
                  id="tile2-original"
                />
              </div>
              <div class="col-md-2">
                <label for="tile2-image" class="form-label small fw-semibold"
                  >Image path / URL</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="tile2-image"
                  required
                />
              </div>
            </div>
          </div>

          <!-- Product Tile 3 (Horizontal) -->
          <div class="card bg-light border-0 p-3 mb-3">
            <h6 class="fw-bold text-primary mb-2">
              <i class="bi bi-3-circle-fill me-2"></i>Product Tile 3 (Horizontal
              Wide)
            </h6>
            <div class="row g-3">
              <div class="col-md-2">
                <label for="tile3-badge" class="form-label small fw-semibold"
                  >Tile Badge</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="tile3-badge"
                  placeholder="Just Launched"
                />
              </div>
              <div class="col-md-3">
                <label for="tile3-name" class="form-label small fw-semibold"
                  >Product Name</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="tile3-name"
                  required
                />
              </div>
              <div class="col-md-3">
                <label for="tile3-desc" class="form-label small fw-semibold"
                  >Short Description</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="tile3-desc"
                  required
                />
              </div>
              <div class="col-md-1">
                <label for="tile3-price" class="form-label small fw-semibold"
                  >Price ($)</label
                >
                <input
                  type="number"
                  step="0.01"
                  class="form-control form-control-sm"
                  id="tile3-price"
                  required
                />
              </div>
              <div class="col-md-1">
                <label for="tile3-original" class="form-label small fw-semibold"
                  >Original ($)</label
                >
                <input
                  type="number"
                  step="0.01"
                  class="form-control form-control-sm"
                  id="tile3-original"
                />
              </div>
              <div class="col-md-2">
                <label for="tile3-image" class="form-label small fw-semibold"
                  >Image path / URL</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="tile3-image"
                  required
                />
              </div>
            </div>
          </div>

          <h5 class="fw-bold mb-3 text-dark border-bottom pb-2 mt-4">
            Hero Trust Indicators
          </h5>
          <div class="row g-3">
            <div class="col-md-3">
              <div class="card p-2 bg-light border-0">
                <label for="trust-icon-1" class="form-label small fw-semibold"
                  >Item 1 Icon Class</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="trust-icon-1"
                  required
                  placeholder="bi-truck"
                />
                <label
                  for="trust-text-1"
                  class="form-label small fw-semibold mt-1">Item 1 Text</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="trust-text-1"
                  required
                  placeholder="Free Shipping"
                />
              </div>
            </div>
            <div class="col-md-3">
              <div class="card p-2 bg-light border-0">
                <label for="trust-icon-2" class="form-label small fw-semibold"
                  >Item 2 Icon Class</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="trust-icon-2"
                  required
                  placeholder="bi-shield-check"
                />
                <label
                  for="trust-text-2"
                  class="form-label small fw-semibold mt-1">Item 2 Text</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="trust-text-2"
                  required
                  placeholder="Verified Quality"
                />
              </div>
            </div>
            <div class="col-md-3">
              <div class="card p-2 bg-light border-0">
                <label for="trust-icon-3" class="form-label small fw-semibold"
                  >Item 3 Icon Class</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="trust-icon-3"
                  required
                  placeholder="bi-arrow-return-left"
                />
                <label
                  for="trust-text-3"
                  class="form-label small fw-semibold mt-1">Item 3 Text</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="trust-text-3"
                  required
                  placeholder="Easy Returns"
                />
              </div>
            </div>
            <div class="col-md-3">
              <div class="card p-2 bg-light border-0">
                <label for="trust-icon-4" class="form-label small fw-semibold"
                  >Item 4 Icon Class</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="trust-icon-4"
                  required
                  placeholder="bi-chat-dots"
                />
                <label
                  for="trust-text-4"
                  class="form-label small fw-semibold mt-1">Item 4 Text</label
                >
                <input
                  type="text"
                  class="form-control form-control-sm"
                  id="trust-text-4"
                  required
                  placeholder="24/7 Support"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- 2. PROMO SECTION TAB -->
        <div
          class="tab-pane fade"
          id="promo-panel"
          role="tabpanel"
          aria-labelledby="promo-tab"
        >
          <h5 class="fw-bold mb-3 text-dark border-bottom pb-2">
            Promo Banner Showcase (Winter Lookbook)
          </h5>

          <div class="row g-3">
            <div class="col-md-4">
              <label for="promo-tag" class="form-label fw-semibold"
                >Tag Label</label
              >
              <input
                type="text"
                class="form-control"
                id="promo-tag"
                required
                placeholder="e.g. New Season"
              />
            </div>
            <div class="col-md-8">
              <label for="promo-title" class="form-label fw-semibold"
                >Promo Title</label
              >
              <input
                type="text"
                class="form-control"
                id="promo-title"
                required
                placeholder="e.g. Winter Lookbook"
              />
            </div>
            <div class="col-12">
              <label for="promo-description" class="form-label fw-semibold"
                >Promo Description</label
              >
              <textarea
                class="form-control"
                id="promo-description"
                rows="3"
                required
                placeholder="Description of the lookbook/promo..."></textarea>
            </div>
            <div class="col-md-6">
              <label for="promo-image" class="form-label fw-semibold"
                >Showcase Image Path / URL</label
              >
              <input
                type="text"
                class="form-control"
                id="promo-image"
                required
                placeholder="/shop/assets/img/...webp"
              />
            </div>
            <div class="col-md-3">
              <label for="promo-btn-text" class="form-label fw-semibold"
                >Button Text</label
              >
              <input
                type="text"
                class="form-control"
                id="promo-btn-text"
                required
                placeholder="Explore Collection"
              />
            </div>
            <div class="col-md-3">
              <label for="promo-btn-link" class="form-label fw-semibold"
                >Button Link</label
              >
              <input
                type="text"
                class="form-control"
                id="promo-btn-link"
                required
                placeholder="/category"
              />
            </div>
          </div>

          <h6 class="fw-bold text-dark mt-4 mb-2">
            Highlight Bullet Features (up to 3 items)
          </h6>
          <div class="row g-2">
            <div class="col-md-4">
              <label for="promo-bullet-1" class="form-label small fw-semibold"
                >Bullet 1</label
              >
              <input
                type="text"
                class="form-control"
                id="promo-bullet-1"
                required
                placeholder="e.g. Curated seasonal selections"
              />
            </div>
            <div class="col-md-4">
              <label for="promo-bullet-2" class="form-label small fw-semibold"
                >Bullet 2</label
              >
              <input
                type="text"
                class="form-control"
                id="promo-bullet-2"
                required
                placeholder="e.g. Exclusive online availability"
              />
            </div>
            <div class="col-md-4">
              <label for="promo-bullet-3" class="form-label small fw-semibold"
                >Bullet 3</label
              >
              <input
                type="text"
                class="form-control"
                id="promo-bullet-3"
                required
                placeholder="e.g. Complimentary shipping included"
              />
            </div>
          </div>

          <h5 class="fw-bold mb-3 text-dark border-bottom pb-2 mt-4">
            Best Sellers Section Header
          </h5>
          <div class="row g-3">
            <div class="col-md-4">
              <label for="best-sellers-title" class="form-label fw-semibold"
                >Section Title</label
              >
              <input
                type="text"
                class="form-control"
                id="best-sellers-title"
                required
                placeholder="Best Sellers"
              />
            </div>
            <div class="col-md-8">
              <label for="best-sellers-subtitle" class="form-label fw-semibold"
                >Section Subtitle</label
              >
              <input
                type="text"
                class="form-control"
                id="best-sellers-subtitle"
                required
                placeholder="Featured items hand-picked..."
              />
            </div>
          </div>
        </div>

        <!-- 3. LAYOUT & FOOTER TAB -->
        <div
          class="tab-pane fade"
          id="layout-panel"
          role="tabpanel"
          aria-labelledby="layout-tab"
        >
          <h5 class="fw-bold mb-3 text-dark border-bottom pb-2">
            Header settings
          </h5>
          <div class="row g-3 mb-4">
            <div class="col-12">
              <label for="layout-utility-promo" class="form-label fw-semibold"
                >Top Utility Bar Promo Text</label
              >
              <input
                type="text"
                class="form-control"
                id="layout-utility-promo"
                required
                placeholder="e.g. Free delivery on orders over $75"
              />
            </div>
          </div>

          <h5 class="fw-bold mb-3 text-dark border-bottom pb-2">
            Footer Contact & About Information
          </h5>
          <div class="row g-3 mb-4">
            <div class="col-12">
              <label for="layout-footer-desc" class="form-label fw-semibold"
                >Footer About Shop Description</label
              >
              <textarea
                class="form-control"
                id="layout-footer-desc"
                rows="3"
                required
                placeholder="Brief shop description in footer..."></textarea>
            </div>
            <div class="col-md-4">
              <label for="layout-address" class="form-label fw-semibold"
                >Contact Address</label
              >
              <input
                type="text"
                class="form-control"
                id="layout-address"
                required
                placeholder="123 Fashion Street, New York, NY 10001"
              />
            </div>
            <div class="col-md-4">
              <label for="layout-phone" class="form-label fw-semibold"
                >Contact Phone Number</label
              >
              <input
                type="text"
                class="form-control"
                id="layout-phone"
                required
                placeholder="+1 (555) 123-4567"
              />
            </div>
            <div class="col-md-4">
              <label for="layout-email" class="form-label fw-semibold"
                >Contact Email Address</label
              >
              <input
                type="email"
                class="form-control"
                id="layout-email"
                required
                placeholder="hello@example.com"
              />
            </div>
          </div>

          <h5 class="fw-bold mb-3 text-dark border-bottom pb-2">
            Footer Newsletter Settings
          </h5>
          <div class="row g-3">
            <div class="col-md-4">
              <label
                for="layout-newsletter-title"
                class="form-label fw-semibold">Newsletter Title</label
              >
              <input
                type="text"
                class="form-control"
                id="layout-newsletter-title"
                required
                placeholder="Join Our Newsletter"
              />
            </div>
            <div class="col-md-8">
              <label for="layout-newsletter-desc" class="form-label fw-semibold"
                >Newsletter Description</label
              >
              <input
                type="text"
                class="form-control"
                id="layout-newsletter-desc"
                required
                placeholder="Subscribe to get special offers, free giveaways..."
              />
            </div>
          </div>
        </div>

        <!-- 4. SHIPPING RATES TAB -->
        <div
          class="tab-pane fade"
          id="shipping-panel"
          role="tabpanel"
          aria-labelledby="shipping-tab"
        >
          <h5 class="fw-bold mb-3 text-dark border-bottom pb-2">
            Manage Province Shipping Rates
          </h5>
          <p class="text-muted small">
            Set custom shipping costs for each province. Customers will see
            these rates applied during checkout.
          </p>

          <!-- Inline Form for adding/editing a rate -->
          <div class="card bg-light border-0 p-4 mb-4 shadow-sm rounded-3">
            <h6 class="fw-bold text-primary mb-3" id="shipping-form-title">
              <i class="bi bi-plus-circle-fill me-2"></i>Add Province Rate
            </h6>
            <input type="hidden" id="shipping-rate-id" value="" />
            <div class="row g-3 align-items-end">
              <div class="col-md-5">
                <label
                  for="shipping-province"
                  class="form-label small fw-bold text-secondary"
                  >Province Name *</label
                >
                <input
                  type="text"
                  class="form-control"
                  id="shipping-province"
                  placeholder="e.g. Jawa Timur"
                />
              </div>
              <div class="col-md-4">
                <label
                  for="shipping-rate"
                  class="form-label small fw-bold text-secondary"
                  >Shipping Cost ($) *</label
                >
                <input
                  type="number"
                  step="0.01"
                  min="0"
                  class="form-control"
                  id="shipping-rate"
                  placeholder="e.g. 10.00"
                />
              </div>
              <div class="col-md-3">
                <button
                  type="button"
                  class="btn btn-primary w-100 fw-bold py-2"
                  id="btn-save-shipping-rate"
                >
                  <i class="bi bi-save me-1"></i> Save Rate
                </button>
              </div>
            </div>
          </div>

          <!-- Shipping Rates Table -->
          <div class="table-responsive bg-white rounded-3 border">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-4">Province</th>
                  <th>Shipping Cost</th>
                  <th class="text-end pe-4">Actions</th>
                </tr>
              </thead>
              <tbody id="shipping-rates-table-body">
                <tr>
                  <td colspan="3" class="text-center py-4 text-muted">
                    <span class="spinner-border spinner-border-sm me-2"
                    ></span>Loading shipping rates...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="border-top pt-3 mt-4 text-end">
        <button
          type="submit"
          class="btn btn-primary d-flex align-items-center gap-2 ms-auto py-2 px-4 fw-semibold"
          id="save-btn"
        >
          <i class="bi bi-save"></i>
          <span>Save Changes</span>
          <span
            id="save-spinner"
            class="spinner-border spinner-border-sm d-none"
            role="status"
            aria-hidden="true"></span>
        </button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  import { supabase } from "../../lib/supabase";

  const alertContainer = document.getElementById("alert-container");
  const settingsForm = document.getElementById(
    "settings-form",
  ) as HTMLFormElement;
  const saveBtn = document.getElementById("save-btn") as HTMLButtonElement;
  const saveSpinner = document.getElementById("save-spinner");

  function showAlert(message: string, type: "danger" | "success") {
    if (!alertContainer) return;
    alertContainer.innerHTML = `
      <div class="alert alert-${type} alert-dismissible fade show border-0 rounded-3 mb-4" role="alert">
        <i class="bi ${type === "danger" ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill"} me-2"></i>
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    `;
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  async function checkSuperAdmin() {
    const {
      data: { session },
    } = await supabase.auth.getSession();
    if (!session || !session.user) {
      window.location.href = "/admin/login";
      return;
    }

    const { data: profile } = await supabase
      .from("profiles")
      .select("role")
      .eq("id", session.user.id)
      .single();

    if (profile?.role !== "super_admin") {
      alert("Access Denied: Only the Super Admin can manage website settings.");
      window.location.href = "/admin";
      return;
    }

    loadSettings();
  }

  async function loadSettings() {
    try {
      const {
        data: { session },
      } = await supabase.auth.getSession();
      if (!session) return;

      loadShippingRates();

      const res = await fetch("/api/admin/settings", {
        headers: {
          Authorization: `Bearer ${session.access_token}`,
        },
      });

      const result = await res.json();
      if (!res.ok || !result.success) {
        showAlert(
          result.error ||
            "Failed to load site settings from database. Verify table is created.",
          "danger",
        );
        return;
      }

      const settings = result.data;

      // Parse homepage settings
      const homepage = settings.find((s: any) => s.key === "homepage")?.value;
      if (homepage) {
        // Hero Section
        if (homepage.hero) {
          (document.getElementById("hero-badge") as HTMLInputElement).value =
            homepage.hero.badge_label || "";
          (document.getElementById("hero-title") as HTMLInputElement).value =
            homepage.hero.headline || "";
          (
            document.getElementById("hero-subtext") as HTMLTextAreaElement
          ).value = homepage.hero.subtext || "";
          (
            document.getElementById("hero-btn1-text") as HTMLInputElement
          ).value = homepage.hero.btn_primary_text || "";
          (
            document.getElementById("hero-btn1-link") as HTMLInputElement
          ).value = homepage.hero.btn_primary_link || "";
          (
            document.getElementById("hero-btn2-text") as HTMLInputElement
          ).value = homepage.hero.btn_ghost_text || "";
          (
            document.getElementById("hero-btn2-link") as HTMLInputElement
          ).value = homepage.hero.btn_ghost_link || "";

          if (homepage.hero.tile1) {
            (document.getElementById("tile1-badge") as HTMLInputElement).value =
              homepage.hero.tile1.badge || "";
            (document.getElementById("tile1-name") as HTMLInputElement).value =
              homepage.hero.tile1.name || "";
            (document.getElementById("tile1-price") as HTMLInputElement).value =
              homepage.hero.tile1.price || "";
            (
              document.getElementById("tile1-original") as HTMLInputElement
            ).value = homepage.hero.tile1.original_price || "";
            (document.getElementById("tile1-image") as HTMLInputElement).value =
              homepage.hero.tile1.image || "";
          }

          if (homepage.hero.tile2) {
            (document.getElementById("tile2-badge") as HTMLInputElement).value =
              homepage.hero.tile2.badge || "";
            (document.getElementById("tile2-name") as HTMLInputElement).value =
              homepage.hero.tile2.name || "";
            (document.getElementById("tile2-price") as HTMLInputElement).value =
              homepage.hero.tile2.price || "";
            (
              document.getElementById("tile2-original") as HTMLInputElement
            ).value = homepage.hero.tile2.original_price || "";
            (document.getElementById("tile2-image") as HTMLInputElement).value =
              homepage.hero.tile2.image || "";
          }

          if (homepage.hero.tile3) {
            (document.getElementById("tile3-badge") as HTMLInputElement).value =
              homepage.hero.tile3.badge || "";
            (document.getElementById("tile3-name") as HTMLInputElement).value =
              homepage.hero.tile3.name || "";
            (document.getElementById("tile3-desc") as HTMLInputElement).value =
              homepage.hero.tile3.desc || "";
            (document.getElementById("tile3-price") as HTMLInputElement).value =
              homepage.hero.tile3.price || "";
            (
              document.getElementById("tile3-original") as HTMLInputElement
            ).value = homepage.hero.tile3.original_price || "";
            (document.getElementById("tile3-image") as HTMLInputElement).value =
              homepage.hero.tile3.image || "";
          }
        }

        // Promo Section
        if (homepage.promo) {
          (document.getElementById("promo-tag") as HTMLInputElement).value =
            homepage.promo.tag || "";
          (document.getElementById("promo-title") as HTMLInputElement).value =
            homepage.promo.title || "";
          (
            document.getElementById("promo-description") as HTMLTextAreaElement
          ).value = homepage.promo.description || "";
          (document.getElementById("promo-image") as HTMLInputElement).value =
            homepage.promo.image || "";
          (
            document.getElementById("promo-btn-text") as HTMLInputElement
          ).value = homepage.promo.btn_text || "";
          (
            document.getElementById("promo-btn-link") as HTMLInputElement
          ).value = homepage.promo.btn_link || "";

          const bullets = homepage.promo.bullets || [];
          (
            document.getElementById("promo-bullet-1") as HTMLInputElement
          ).value = bullets[0] || "";
          (
            document.getElementById("promo-bullet-2") as HTMLInputElement
          ).value = bullets[1] || "";
          (
            document.getElementById("promo-bullet-3") as HTMLInputElement
          ).value = bullets[2] || "";
        }

        // Best Sellers Section
        if (homepage.best_sellers) {
          (
            document.getElementById("best-sellers-title") as HTMLInputElement
          ).value = homepage.best_sellers.title || "";
          (
            document.getElementById("best-sellers-subtitle") as HTMLInputElement
          ).value = homepage.best_sellers.subtitle || "";
        }

        // Trust Indicators Section
        if (homepage.trust_indicators) {
          if (homepage.trust_indicators.item1) {
            (
              document.getElementById("trust-icon-1") as HTMLInputElement
            ).value = homepage.trust_indicators.item1.icon || "";
            (
              document.getElementById("trust-text-1") as HTMLInputElement
            ).value = homepage.trust_indicators.item1.text || "";
          }
          if (homepage.trust_indicators.item2) {
            (
              document.getElementById("trust-icon-2") as HTMLInputElement
            ).value = homepage.trust_indicators.item2.icon || "";
            (
              document.getElementById("trust-text-2") as HTMLInputElement
            ).value = homepage.trust_indicators.item2.text || "";
          }
          if (homepage.trust_indicators.item3) {
            (
              document.getElementById("trust-icon-3") as HTMLInputElement
            ).value = homepage.trust_indicators.item3.icon || "";
            (
              document.getElementById("trust-text-3") as HTMLInputElement
            ).value = homepage.trust_indicators.item3.text || "";
          }
          if (homepage.trust_indicators.item4) {
            (
              document.getElementById("trust-icon-4") as HTMLInputElement
            ).value = homepage.trust_indicators.item4.icon || "";
            (
              document.getElementById("trust-text-4") as HTMLInputElement
            ).value = homepage.trust_indicators.item4.text || "";
          }
        }
      }

      // Parse layout settings
      const layout = settings.find((s: any) => s.key === "layout")?.value;
      if (layout) {
        (
          document.getElementById("layout-utility-promo") as HTMLInputElement
        ).value = layout.utility_promo_text || "";
        (
          document.getElementById("layout-footer-desc") as HTMLTextAreaElement
        ).value = layout.footer_desc || "";
        (document.getElementById("layout-address") as HTMLInputElement).value =
          layout.contact_address || "";
        (document.getElementById("layout-phone") as HTMLInputElement).value =
          layout.contact_phone || "";
        (document.getElementById("layout-email") as HTMLInputElement).value =
          layout.contact_email || "";
        (
          document.getElementById("layout-newsletter-title") as HTMLInputElement
        ).value = layout.newsletter_title || "";
        (
          document.getElementById("layout-newsletter-desc") as HTMLInputElement
        ).value = layout.newsletter_desc || "";
      }
    } catch (err: any) {
      console.error(err);
      showAlert("Failed to connect to web settings API.", "danger");
    }
  }

  // Handle save configurations
  settingsForm?.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (saveBtn) saveBtn.disabled = true;
    saveSpinner?.classList.remove("d-none");

    // 1. Gather Homepage Object
    const homepageValue = {
      hero: {
        badge_label: (document.getElementById("hero-badge") as HTMLInputElement)
          .value,
        headline: (document.getElementById("hero-title") as HTMLInputElement)
          .value,
        subtext: (
          document.getElementById("hero-subtext") as HTMLTextAreaElement
        ).value,
        btn_primary_text: (
          document.getElementById("hero-btn1-text") as HTMLInputElement
        ).value,
        btn_primary_link: (
          document.getElementById("hero-btn1-link") as HTMLInputElement
        ).value,
        btn_ghost_text: (
          document.getElementById("hero-btn2-text") as HTMLInputElement
        ).value,
        btn_ghost_link: (
          document.getElementById("hero-btn2-link") as HTMLInputElement
        ).value,
        tile1: {
          badge: (document.getElementById("tile1-badge") as HTMLInputElement)
            .value,
          name: (document.getElementById("tile1-name") as HTMLInputElement)
            .value,
          price: Number(
            (document.getElementById("tile1-price") as HTMLInputElement).value,
          ),
          original_price: (
            document.getElementById("tile1-original") as HTMLInputElement
          ).value
            ? Number(
                (document.getElementById("tile1-original") as HTMLInputElement)
                  .value,
              )
            : null,
          image: (document.getElementById("tile1-image") as HTMLInputElement)
            .value,
        },
        tile2: {
          badge: (document.getElementById("tile2-badge") as HTMLInputElement)
            .value,
          name: (document.getElementById("tile2-name") as HTMLInputElement)
            .value,
          price: Number(
            (document.getElementById("tile2-price") as HTMLInputElement).value,
          ),
          original_price: (
            document.getElementById("tile2-original") as HTMLInputElement
          ).value
            ? Number(
                (document.getElementById("tile2-original") as HTMLInputElement)
                  .value,
              )
            : null,
          image: (document.getElementById("tile2-image") as HTMLInputElement)
            .value,
        },
        tile3: {
          badge: (document.getElementById("tile3-badge") as HTMLInputElement)
            .value,
          name: (document.getElementById("tile3-name") as HTMLInputElement)
            .value,
          desc: (document.getElementById("tile3-desc") as HTMLInputElement)
            .value,
          price: Number(
            (document.getElementById("tile3-price") as HTMLInputElement).value,
          ),
          original_price: (
            document.getElementById("tile3-original") as HTMLInputElement
          ).value
            ? Number(
                (document.getElementById("tile3-original") as HTMLInputElement)
                  .value,
              )
            : null,
          image: (document.getElementById("tile3-image") as HTMLInputElement)
            .value,
        },
      },
      promo: {
        image: (document.getElementById("promo-image") as HTMLInputElement)
          .value,
        tag: (document.getElementById("promo-tag") as HTMLInputElement).value,
        title: (document.getElementById("promo-title") as HTMLInputElement)
          .value,
        description: (
          document.getElementById("promo-description") as HTMLTextAreaElement
        ).value,
        bullets: [
          (document.getElementById("promo-bullet-1") as HTMLInputElement).value,
          (document.getElementById("promo-bullet-2") as HTMLInputElement).value,
          (document.getElementById("promo-bullet-3") as HTMLInputElement).value,
        ].filter(Boolean),
        btn_text: (
          document.getElementById("promo-btn-text") as HTMLInputElement
        ).value,
        btn_link: (
          document.getElementById("promo-btn-link") as HTMLInputElement
        ).value,
      },
      best_sellers: {
        title: (
          document.getElementById("best-sellers-title") as HTMLInputElement
        ).value,
        subtitle: (
          document.getElementById("best-sellers-subtitle") as HTMLInputElement
        ).value,
      },
      trust_indicators: {
        item1: {
          icon: (document.getElementById("trust-icon-1") as HTMLInputElement)
            .value,
          text: (document.getElementById("trust-text-1") as HTMLInputElement)
            .value,
        },
        item2: {
          icon: (document.getElementById("trust-icon-2") as HTMLInputElement)
            .value,
          text: (document.getElementById("trust-text-2") as HTMLInputElement)
            .value,
        },
        item3: {
          icon: (document.getElementById("trust-icon-3") as HTMLInputElement)
            .value,
          text: (document.getElementById("trust-text-3") as HTMLInputElement)
            .value,
        },
        item4: {
          icon: (document.getElementById("trust-icon-4") as HTMLInputElement)
            .value,
          text: (document.getElementById("trust-text-4") as HTMLInputElement)
            .value,
        },
      },
    };

    // 2. Gather Layout Object
    const layoutValue = {
      utility_promo_text: (
        document.getElementById("layout-utility-promo") as HTMLInputElement
      ).value,
      footer_desc: (
        document.getElementById("layout-footer-desc") as HTMLTextAreaElement
      ).value,
      contact_address: (
        document.getElementById("layout-address") as HTMLInputElement
      ).value,
      contact_phone: (
        document.getElementById("layout-phone") as HTMLInputElement
      ).value,
      contact_email: (
        document.getElementById("layout-email") as HTMLInputElement
      ).value,
      newsletter_title: (
        document.getElementById("layout-newsletter-title") as HTMLInputElement
      ).value,
      newsletter_desc: (
        document.getElementById("layout-newsletter-desc") as HTMLInputElement
      ).value,
    };

    try {
      const {
        data: { session },
      } = await supabase.auth.getSession();
      if (!session) throw new Error("No active session");

      // Save homepage settings
      const resHome = await fetch("/api/admin/settings", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${session.access_token}`,
        },
        body: JSON.stringify({ key: "homepage", value: homepageValue }),
      });

      // Save layout settings
      const resLayout = await fetch("/api/admin/settings", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${session.access_token}`,
        },
        body: JSON.stringify({ key: "layout", value: layoutValue }),
      });

      const homeResult = await resHome.json();
      const layoutResult = await resLayout.json();

      if (
        !resHome.ok ||
        !resLayout.ok ||
        !homeResult.success ||
        !layoutResult.success
      ) {
        throw new Error(
          homeResult.error || layoutResult.error || "Failed to save settings",
        );
      }

      showAlert("Website settings updated successfully!", "success");
      loadSettings();
    } catch (err: any) {
      console.error(err);
      showAlert(`An error occurred while saving: ${err.message}`, "danger");
    } finally {
      if (saveBtn) saveBtn.disabled = false;
      saveSpinner?.classList.add("d-none");
    }
  });

  // --- SHIPPING RATES CRUD LOGIC ---
  const shippingTableBody = document.getElementById(
    "shipping-rates-table-body",
  );
  const btnSaveShipping = document.getElementById(
    "btn-save-shipping-rate",
  ) as HTMLButtonElement;
  const inputRateId = document.getElementById(
    "shipping-rate-id",
  ) as HTMLInputElement;
  const inputProvince = document.getElementById(
    "shipping-province",
  ) as HTMLInputElement;
  const inputRate = document.getElementById(
    "shipping-rate",
  ) as HTMLInputElement;
  const formTitle = document.getElementById("shipping-form-title");

  async function loadShippingRates() {
    if (!shippingTableBody) return;

    try {
      const {
        data: { session },
      } = await supabase.auth.getSession();
      if (!session) return;

      const res = await fetch("/api/admin/shipping-rates", {
        headers: {
          Authorization: `Bearer ${session.access_token}`,
        },
      });

      const result = await res.json();
      if (!res.ok || !result.success) {
        shippingTableBody.innerHTML = `
          <tr>
            <td colspan="3" class="text-center text-danger py-4 small">
              <i class="bi bi-exclamation-triangle me-1"></i> ${result.error || "Failed to load shipping rates."}
            </td>
          </tr>
        `;
        return;
      }

      const rates = result.data || [];
      if (rates.length === 0) {
        shippingTableBody.innerHTML = `
          <tr>
            <td colspan="3" class="text-center py-4 text-muted small">
              No shipping rates defined yet. Add one above.
            </td>
          </tr>
        `;
        return;
      }

      shippingTableBody.innerHTML = rates
        .map(
          (r: any) => `
        <tr>
          <td class="ps-4 fw-semibold text-dark">${r.province}</td>
          <td class="fw-bold text-primary">$${Number(r.rate).toFixed(2)}</td>
          <td class="text-end pe-4">
            <button type="button" class="btn btn-sm btn-outline-primary me-2 py-1 px-2.5" onclick="window.editShippingRate('${r.id}', '${r.province.replace(/'/g, "\\'")}', ${r.rate})">
              <i class="bi bi-pencil-square"></i> Edit
            </button>
            <button type="button" class="btn btn-sm btn-outline-danger py-1 px-2.5" onclick="window.deleteShippingRate('${r.id}')">
              <i class="bi bi-trash"></i> Delete
            </button>
          </td>
        </tr>
      `,
        )
        .join("");
    } catch (err) {
      console.error(err);
      shippingTableBody.innerHTML = `
        <tr>
          <td colspan="3" class="text-center text-danger py-4 small">
            <i class="bi bi-exclamation-triangle me-1"></i> An error occurred while retrieving shipping rates.
          </td>
        </tr>
      `;
    }
  }

  // Expose to window for inline onclick triggers
  (window as any).editShippingRate = function (
    id: string,
    province: string,
    rate: number,
  ) {
    if (inputRateId) inputRateId.value = id;
    if (inputProvince) inputProvince.value = province;
    if (inputRate) inputRate.value = String(rate);
    if (formTitle)
      formTitle.innerHTML = `<i class="bi bi-pencil-square me-2"></i>Edit Province Rate`;
    if (inputProvince) inputProvince.focus();
  };

  (window as any).deleteShippingRate = async function (id: string) {
    if (
      !confirm("Are you sure you want to delete this province shipping rate?")
    )
      return;

    try {
      const {
        data: { session },
      } = await supabase.auth.getSession();
      if (!session) return;

      const res = await fetch(`/api/admin/shipping-rates?id=${id}`, {
        method: "DELETE",
        headers: {
          Authorization: `Bearer ${session.access_token}`,
        },
      });

      const result = await res.json();
      if (res.ok && result.success) {
        loadShippingRates();
      } else {
        alert(result.error || "Failed to delete shipping rate");
      }
    } catch (err) {
      console.error(err);
      alert("An error occurred while deleting shipping rate.");
    }
  };

  btnSaveShipping?.addEventListener("click", async () => {
    const province = inputProvince.value.trim();
    const rate = parseFloat(inputRate.value);

    if (!province || isNaN(rate)) {
      alert("Please fill in both Province Name and a valid Shipping Cost.");
      return;
    }

    try {
      const {
        data: { session },
      } = await supabase.auth.getSession();
      if (!session) return;

      const rateId = inputRateId.value;
      const isEdit = !!rateId;

      const payload = isEdit
        ? { id: rateId, province, rate }
        : { province, rate };
      const method = isEdit ? "PUT" : "POST";

      btnSaveShipping.disabled = true;
      btnSaveShipping.innerHTML =
        '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';

      const res = await fetch("/api/admin/shipping-rates", {
        method,
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${session.access_token}`,
        },
        body: JSON.stringify(payload),
      });

      const result = await res.json();
      if (res.ok && result.success) {
        // Reset form
        inputRateId.value = "";
        inputProvince.value = "";
        inputRate.value = "";
        if (formTitle)
          formTitle.innerHTML = `<i class="bi bi-plus-circle-fill me-2"></i>Add Province Rate`;

        loadShippingRates();
      } else {
        alert(result.error || "Failed to save shipping rate.");
      }
    } catch (err: any) {
      console.error(err);
      alert("An error occurred while saving the shipping rate.");
    } finally {
      btnSaveShipping.disabled = false;
      btnSaveShipping.innerHTML = '<i class="bi bi-save me-1"></i> Save Rate';
    }
  });

  checkSuperAdmin();
</script>

<style>
  /* Bordered tab indicators style */
  .nav-tabs-buffered .nav-link {
    border: none;
    border-bottom: 3px solid transparent;
    padding: 0.75rem 1.25rem;
    color: #495057;
    transition: all 0.2s ease-in-out;
  }
  .nav-tabs-buffered .nav-link:hover {
    color: var(--bs-primary);
    border-bottom-color: rgba(var(--bs-primary-rgb), 0.3);
  }
  .nav-tabs-buffered .nav-link.active {
    color: var(--bs-primary);
    border-bottom-color: var(--bs-primary);
    background-color: transparent;
  }
</style>
