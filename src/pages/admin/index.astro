---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createClient } from '@supabase/supabase-js';

const supabaseAdmin = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

let totalRevenue = 0;
let totalOrders = 0;
let lowStockCount = 0;
let recentOrders: any[] = [];

try {
  // Fetch total orders and revenue
  const { data: dbOrders } = await supabaseAdmin
    .from('orders')
    .select('total_amount, status');
  
  if (dbOrders) {
    totalOrders = dbOrders.length;
    totalRevenue = dbOrders
      .filter(o => o.status !== 'cancelled')
      .reduce((sum, o) => sum + Number(o.total_amount), 0);
  }

  // Fetch low stock count
  const { count: dbLowStock } = await supabaseAdmin
    .from('products')
    .select('*', { count: 'exact', head: true })
    .lte('stock', 5);
  
  lowStockCount = dbLowStock || 0;

  // Fetch recent orders
  const { data: dbRecentOrders } = await supabaseAdmin
    .from('orders')
    .select('*')
    .order('created_at', { ascending: false })
    .limit(5);
  
  if (dbRecentOrders) {
    recentOrders = dbRecentOrders;
  }
} catch (e) {
  console.error("Failed to fetch admin stats:", e);
}
---
<AdminLayout title="Dashboard - EasyAdmin">
  <div class="page-header d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
      <h1 class="page-title h3 mb-1 font-weight-bold">Dashboard</h1>
      <p class="text-muted mb-0">Overview of your e-commerce operations connected to Supabase.</p>
    </div>
  </div>

  <!-- Bento Grid / Metrics Row -->
  <div class="row g-4 mb-4">
    <!-- Total Revenue Card -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm p-4 bg-white h-100">
        <div class="d-flex align-items-start justify-content-between">
          <div>
            <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size: 0.8rem; letter-spacing: 0.5px;">Total Revenue</p>
            <h2 class="mb-0 fw-bold text-dark">${totalRevenue.toFixed(2)}</h2>
          </div>
          <div class="rounded-3 p-3 bg-primary-light text-primary">
            <i class="bi bi-graph-up-arrow fs-4"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Total Orders Card -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm p-4 bg-white h-100">
        <div class="d-flex align-items-start justify-content-between">
          <div>
            <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size: 0.8rem; letter-spacing: 0.5px;">Total Orders</p>
            <h2 class="mb-0 fw-bold text-dark">{totalOrders}</h2>
          </div>
          <div class="rounded-3 p-3 bg-success-light text-success">
            <i class="bi bi-cart-check fs-4"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Low Stock Alert Card -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm p-4 bg-white h-100">
        <div class="d-flex align-items-start justify-content-between">
          <div>
            <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size: 0.8rem; letter-spacing: 0.5px;">Low Stock Alerts</p>
            <h2 class="mb-0 fw-bold text-dark">{lowStockCount} items</h2>
          </div>
          <div class="rounded-3 p-3 bg-warning-light text-warning">
            <i class="bi bi-exclamation-triangle fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <!-- Recent Orders List -->
    <div class="col-12">
      <div class="card border-0 shadow-sm p-4 bg-white mb-4">
        <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-2">
          <h5 class="fw-bold mb-0">Recent Orders</h5>
          <a href="/admin/orders" class="btn btn-sm btn-outline-primary">View All Orders</a>
        </div>

        {recentOrders.length === 0 ? (
          <div class="text-center py-5">
            <i class="bi bi-cart-x text-muted" style="font-size: 2.5rem;"></i>
            <p class="text-muted mt-3 mb-0">No orders placed yet.</p>
          </div>
        ) : (
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Order ID</th>
                  <th>Customer & Shipping</th>
                  <th>Total Amount</th>
                  <th>Payment Method</th>
                  <th>Status</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                {recentOrders.map(o => (
                  <tr>
                    <td class="font-monospace text-muted" style="font-size: 0.85rem;">{o.id}</td>
                    <td>
                      <div class="fw-semibold">{o.shipping_address.split('|')[0] || 'Guest'}</div>
                      <div class="text-muted small" style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        {o.shipping_address.split('|')[2] || o.shipping_address}
                      </div>
                    </td>
                    <td class="fw-bold text-primary">${Number(o.total_amount).toFixed(2)}</td>
                    <td class="text-uppercase small">{o.payment_method}</td>
                    <td>
                      <span class={`badge ${
                        o.status === 'completed' ? 'bg-success' :
                        o.status === 'pending' ? 'bg-warning' :
                        o.status === 'processing' ? 'bg-info' :
                        'bg-danger'
                      }`}>
                        {o.status}
                      </span>
                    </td>
                    <td class="small text-muted">{new Date(o.created_at).toLocaleDateString()}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  </div>
</AdminLayout>
export const prerender = false;
