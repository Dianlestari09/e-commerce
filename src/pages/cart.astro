---
import ShopLayout from '../layouts/ShopLayout.astro';
---
<ShopLayout title="Shopping Cart - ShopWise">
  <main class="main">

    <!-- Page Title -->
    <div class="page-title light-background">
      <div class="container d-lg-flex justify-content-between align-items-center">
        <h1 class="mb-2 mb-lg-0">Cart</h1>
        <nav class="breadcrumbs">
          <ol>
            <li><a href="/">Home</a></li>
            <li class="current">Cart</li>
          </ol>
        </nav>
      </div>
    </div>

    <!-- Cart Section -->
    <section id="cart" class="cart section">
      <div class="container py-5">
        <div class="row gy-5">
          <div class="col-lg-8">
            <div class="cart-table border rounded p-3 bg-light">
              <div class="table-head d-none d-md-flex row align-items-center fw-bold border-bottom pb-2 mb-3">
                <div class="col-md-5">Product</div>
                <div class="col-md-2 text-center">Price</div>
                <div class="col-md-3 text-center">Quantity</div>
                <div class="col-md-2 text-end">Total</div>
              </div>

              <!-- Container for cart items -->
              <div id="cart-page-items-container">
                <p class="text-center p-5 text-muted">Your cart is loading...</p>
              </div>
            </div>

            <div class="cart-actions d-flex justify-content-between align-items-center mt-4">
              <a href="/category" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Resume Browsing
              </a>
              <button class="btn btn-danger" id="clear-cart-btn" type="button">
                <i class="bi bi-trash3"></i> Clear All
              </button>
            </div>
          </div>

          <div class="col-lg-4">
            <div class="summary-card border rounded p-4 bg-light">
              <div class="summary-header mb-3 border-bottom pb-2">
                <h5 class="fw-bold">Order Summary</h5>
                <span class="items-count text-muted" id="summary-items-count">0 items</span>
              </div>

              <div class="summary-body">
                <div class="summary-lines">
                  <div class="summary-row d-flex justify-content-between mb-2">
                    <span class="label-text text-muted">Subtotal</span>
                    <span class="value-text fw-semibold" id="summary-subtotal">$0.00</span>
                  </div>

                  <div class="summary-row d-flex justify-content-between mb-2">
                    <span class="label-text text-muted">Shipping</span>
                    <span class="value-text text-success" id="summary-shipping">FREE</span>
                  </div>

                  <div class="separator my-3 border-top"></div>

                  <div class="summary-row d-flex justify-content-between align-items-center mb-4">
                    <span class="label-text fw-bold" style="font-size: 1.2rem;">Total</span>
                    <span class="value-text fw-bold text-primary" style="font-size: 1.4rem;" id="summary-total">$0.00</span>
                  </div>
                </div>

                <a href="/checkout" class="btn btn-primary w-100 py-3 fw-bold shadow-sm">
                  Proceed to Checkout
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    function renderCartPage() {
      const cart = JSON.parse(localStorage.getItem('cart') || '[]');
      const container = document.getElementById('cart-page-items-container');
      const summaryItems = document.getElementById('summary-items-count');
      const summarySubtotal = document.getElementById('summary-subtotal');
      const summaryTotal = document.getElementById('summary-total');

      if (cart.length === 0) {
        container.innerHTML = `
          <div class="text-center py-5">
            <i class="bi bi-bag text-muted" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Your cart is empty</h4>
            <p class="text-muted">Browse our collection and add some items!</p>
            <a href="/category" class="btn btn-primary mt-2">Go Shopping</a>
          </div>
        `;
        summaryItems.textContent = '0 items';
        summarySubtotal.textContent = '$0.00';
        summaryTotal.textContent = '$0.00';
        return;
      }

      // Render cart items
      container.innerHTML = cart.map((item, idx) => `
        <div class="cart-item border-bottom py-3 mb-3">
          <div class="row align-items-center g-3">
            <div class="col-md-5">
              <div class="product-info d-flex align-items-center gap-3">
                <div class="product-img" style="width: 80px; height: 80px;">
                  <img src="${item.image || '/shop/assets/img/product/product-default.webp'}" alt="${item.name}" class="img-fluid rounded border w-100 h-100 object-fit-cover">
                </div>
                <div class="product-meta">
                  <h6 class="product-title fw-bold mb-1"><a href="/product/${item.id}" class="text-dark text-decoration-none">${item.name}</a></h6>
                </div>
              </div>
            </div>
            <div class="col-md-2 col-6 text-md-center">
              <span class="current-price">$${item.price.toFixed(2)}</span>
            </div>
            <div class="col-md-3 col-6 d-flex justify-content-md-center">
              <div class="quantity-selector d-flex align-items-center border rounded">
                <button class="quantity-btn btn border-0 py-1 px-2" type="button" onclick="updateQty(${idx}, -1)"><i class="bi bi-dash"></i></button>
                <input type="number" class="quantity-input text-center border-0" value="${item.quantity}" readonly style="width: 40px;">
                <button class="quantity-btn btn border-0 py-1 px-2" type="button" onclick="updateQty(${idx}, 1)"><i class="bi bi-plus"></i></button>
              </div>
            </div>
            <div class="col-md-2 col-12 text-md-end font-semibold text-primary">
              <span class="row-total fw-bold">$${(item.price * item.quantity).toFixed(2)}</span>
            </div>
          </div>
          <button class="btn btn-sm btn-link text-danger text-decoration-none mt-2 d-md-none" type="button" onclick="removeCartItem(${idx})">
            <i class="bi bi-trash3"></i> Remove
          </button>
          <button class="remove-btn remove-item btn text-danger border-0 bg-transparent position-absolute d-none d-md-block" type="button" aria-label="Remove item" onclick="removeCartItem(${idx})" style="right: 15px; margin-top: -55px;">
            <i class="bi bi-trash3"></i>
          </button>
        </div>
      `).join('');

      // Update Summary Totals
      const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
      const subtotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);

      summaryItems.textContent = `${totalItems} item${totalItems !== 1 ? 's' : ''}`;
      summarySubtotal.textContent = `$${subtotal.toFixed(2)}`;
      summaryTotal.textContent = `$${subtotal.toFixed(2)}`;
    }

    window.updateQty = function(index, change) {
      const cart = JSON.parse(localStorage.getItem('cart') || '[]');
      if (cart[index]) {
        cart[index].quantity += change;
        if (cart[index].quantity <= 0) {
          cart.splice(index, 1);
        }
        localStorage.setItem('cart', JSON.stringify(cart));
        renderCartPage();
        // Notify header
        window.dispatchEvent(new Event('cart-updated-internal'));
      }
    }

    // Wrap header removal
    const originalRemoveCartItem = window.removeCartItem;
    window.removeCartItem = function(index) {
      originalRemoveCartItem(index);
      renderCartPage();
    }

    // Clear cart
    const clearBtn = document.getElementById('clear-cart-btn');
    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        localStorage.setItem('cart', '[]');
        renderCartPage();
        window.dispatchEvent(new Event('cart-updated-internal'));
      });
    }

    document.addEventListener('DOMContentLoaded', renderCartPage);
  </script>
</ShopLayout>
