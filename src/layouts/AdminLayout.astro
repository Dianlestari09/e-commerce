---
interface Props {
  title?: string;
}

const { title = "Dashboard - EasyAdmin" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content="EasyAdmin - Bootstrap Admin Template">
  <meta name="keywords" content="admin, dashboard, bootstrap">

  <!-- Favicons -->
  <link href="/admin/assets/img/favicon.png" rel="icon">
  <link href="/admin/assets/img/apple-touch-icon.png" rel="apple-touch-icon">

  <!-- Google Fonts - Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Vendor CSS Files -->
  <link href="/admin/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/admin/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <link href="/admin/assets/vendor/remixicon/remixicon.css" rel="stylesheet">
  <link href="/admin/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
  <link href="/admin/assets/vendor/phosphor-icons/phosphor-icons.css" rel="stylesheet">
  <link href="/admin/assets/vendor/lucide-icons/lucide.css" rel="stylesheet">
  <link href="/admin/assets/vendor/simple-datatables/style.css" rel="stylesheet">
  <link href="/admin/assets/vendor/quill/quill.snow.css" rel="stylesheet">
  <link href="/admin/assets/vendor/quill/quill.bubble.css" rel="stylesheet">
  <link href="/admin/assets/vendor/choices.js/choices.min.css" rel="stylesheet">
  <link href="/admin/assets/vendor/flatpickr/flatpickr.min.css" rel="stylesheet">

  <!-- Template Main CSS File -->
  <link href="/admin/assets/css/main.css" rel="stylesheet">
</head>

<body style="display: none;" id="admin-body">
  <!-- Header -->
  <header class="header">
    <!-- Header Left -->
    <div class="header-left">
      <a href="/admin" class="header-logo">
        <img src="/admin/assets/img/logo.webp" alt="EasyAdmin">
        <span>EasyAdmin</span>
      </a>
      <button class="sidebar-toggle" title="Toggle Sidebar">
        <i class="bi bi-list"></i>
      </button>
    </div>

    <!-- Header Search (Desktop) -->
    <div class="header-search">
      <form class="search-form collapsed" action="/admin/search" method="GET">
        <button type="button" class="search-toggle-btn"><i class="bi bi-search"></i></button>
        <input type="search" name="q" placeholder="Search..." autocomplete="off">
      </form>
    </div>

    <!-- Header Right -->
    <div class="header-right">
      <div class="header-actions-desktop">
        <!-- Theme Toggle -->
        <button class="header-action theme-toggle" title="Toggle Theme">
          <i class="bi bi-moon icon-dark"></i>
          <i class="bi bi-sun icon-light"></i>
        </button>

        <!-- Fullscreen Toggle -->
        <button class="header-action fullscreen-toggle" id="fullscreen-btn" title="Fullscreen">
          <i class="bi bi-fullscreen icon-enter"></i>
          <i class="bi bi-fullscreen-exit icon-exit"></i>
        </button>

        <!-- User Profile Info -->
        <div class="d-flex align-items-center gap-2 border-start border-secondary border-opacity-10 ps-3 ms-2">
          <div class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 0.85rem;" id="admin-avatar">
            -
          </div>
          <div class="d-none d-md-block text-start" style="line-height: 1.2;">
            <div class="fw-semibold text-dark" style="font-size: 0.85rem;" id="admin-user-name">Loading...</div>
            <div class="text-muted" style="font-size: 0.7rem;" id="admin-user-role">Role</div>
          </div>
        </div>
      </div>

      <!-- Mobile Actions -->
      <div class="header-actions-mobile">
        <button class="header-action search-toggle" title="Search">
          <i class="bi bi-search"></i>
        </button>
        <button class="header-action mobile-menu-toggle" title="More">
          <i class="bi bi-three-dots-vertical"></i>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile Search -->
  <div class="mobile-search">
    <form class="search-form" action="/admin/search" method="GET">
      <input type="search" name="q" placeholder="Search..." autocomplete="off">
      <button type="submit"><i class="bi bi-search"></i></button>
    </form>
  </div>

  <!-- Mobile Header Menu -->
  <div class="mobile-header-menu">
    <div class="mobile-header-menu-content">
      <button class="mobile-menu-item theme-toggle" title="Toggle Theme">
        <i class="bi bi-moon icon-dark"></i>
        <i class="bi bi-sun icon-light"></i>
        <span class="mobile-menu-label">Theme</span>
      </button>
    </div>
  </div>

  <!-- Sidebar -->
  <aside class="sidebar">
    <!-- Sidebar Header -->
    <div class="sidebar-header">
      <a href="/admin" class="sidebar-logo">
        <img src="/admin/assets/img/logo.webp" alt="EasyAdmin">
        <span class="sidebar-logo-text">
          <span class="sidebar-logo-name">EasyAdmin</span>
          <span class="sidebar-logo-tagline">Admin Panel</span>
        </span>
      </a>
      <button class="sidebar-close">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <!-- Sidebar Navigation -->
    <nav class="sidebar-nav">
      <ul class="nav-menu">
        <li class="nav-item">
          <a class="nav-link" href="/admin" data-tooltip="Dashboard">
            <i class="ph-duotone ph-squares-four"></i>
            <span>Dashboard</span>
          </a>
        </li>

        <li class="nav-heading"><span>E-Commerce</span></li>

        <li class="nav-item">
          <a class="nav-link" href="/admin/products" data-tooltip="Products">
            <i class="ph-duotone ph-package"></i>
            <span>Products</span>
          </a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/admin/categories" data-tooltip="Categories">
            <i class="ph-duotone ph-folders"></i>
            <span>Categories</span>
          </a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/admin/orders" data-tooltip="Orders">
            <i class="ph-duotone ph-shopping-cart"></i>
            <span>Orders</span>
          </a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/admin/articles" data-tooltip="Articles">
            <i class="ph-duotone ph-newspaper"></i>
            <span>Articles</span>
          </a>
        </li>

        <li class="nav-item d-none" id="admin-users-link">
          <a class="nav-link" href="/admin/users" data-tooltip="Users">
            <i class="ph-duotone ph-users-three"></i>
            <span>Admins & Users</span>
          </a>
        </li>

        <li class="nav-item d-none" id="admin-settings-link">
          <a class="nav-link" href="/admin/settings" data-tooltip="Web Settings">
            <i class="ph-duotone ph-gear"></i>
            <span>Web Settings</span>
          </a>
        </li>

        <li class="nav-heading"><span>Site Settings</span></li>
        <li class="nav-item">
          <a class="nav-link" href="/" target="_blank" data-tooltip="View Storefront">
            <i class="ph-duotone ph-storefront"></i>
            <span>View Storefront</span>
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link text-danger" href="#" id="admin-logout-btn" data-tooltip="Log Out">
            <i class="ph-duotone ph-sign-out text-danger"></i>
            <span>Log Out</span>
          </a>
        </li>
      </ul>
    </nav>
  </aside>

  <!-- Sidebar Overlay -->
  <div class="sidebar-overlay"></div>

  <!-- Main Content Wrapper -->
  <main class="main">
    <div class="main-content">
      <slot />
    </div>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-content">
        <div class="footer-links">
          <a href="#">About</a>
          <a href="#">Privacy Policy</a>
          <a href="#">Terms of Service</a>
          <a href="#">Contact</a>
        </div>
        <div class="footer-copyright">
          &copy; 2026 <a href="#">EasyAdmin</a>. All Rights Reserved.
        </div>
      </div>
    </footer>
  </main>

  <!-- Back to Top -->
  <a href="#" class="back-to-top">
    <i class="bi bi-arrow-up"></i>
  </a>

  <!-- Vendor JS Files -->
  <script is:inline src="/admin/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script is:inline src="/admin/assets/vendor/apexcharts/apexcharts.min.js"></script>
  <script is:inline src="/admin/assets/vendor/chart.js/chart.umd.js"></script>
  <script is:inline src="/admin/assets/vendor/echarts/echarts.min.js"></script>
  <script is:inline src="/admin/assets/vendor/simple-datatables/simple-datatables.js"></script>
  <script is:inline src="/admin/assets/vendor/quill/quill.js"></script>
  <script is:inline src="/admin/assets/vendor/tinymce/tinymce.min.js"></script>
  <script is:inline src="/admin/assets/vendor/choices.js/choices.min.js"></script>
  <script is:inline src="/admin/assets/vendor/flatpickr/flatpickr.min.js"></script>

  <!-- Template Main JS Files -->
  <script is:inline src="/admin/assets/js/theme.js"></script>
  <script is:inline src="/admin/assets/js/main.js"></script>
  <script is:inline src="/admin/assets/js/apps-sidebar-toggle.js"></script>

  <!-- Fullscreen Toggle Handler -->
  <script is:inline>
    const fsBtn = document.getElementById('fullscreen-btn');
    if (fsBtn) {
      fsBtn.addEventListener('click', function() {
        if (!document.fullscreenElement) {
          document.documentElement.requestFullscreen().catch(err => {
            console.error(`Error enabling full-screen mode: ${err.message}`);
          });
        } else {
          document.exitFullscreen();
        }
      });
    }
  </script>

  <script>
    import { supabase } from '../lib/supabase';
    (window as any).supabase = supabase;

    async function checkAdminAuth() {
      // Get current session
      const { data: { session } } = await supabase.auth.getSession();

      if (!session || !session.user) {
        window.location.href = '/admin/login';
        return;
      }

      // Check role in profiles table
      const { data: profile, error } = await supabase
        .from('profiles')
        .select('role, full_name')
        .eq('id', session.user.id)
        .single();

      const role = profile?.role;
      if (error || (role !== 'admin' && role !== 'super_admin')) {
        alert('Access Denied: You do not have administrator privileges.');
        window.location.href = '/';
        return;
      }

      // Show Admins & Users link only for super_admin
      const usersLink = document.getElementById('admin-users-link');
      const settingsLink = document.getElementById('admin-settings-link');
      if (role === 'super_admin') {
        usersLink?.classList.remove('d-none');
        settingsLink?.classList.remove('d-none');
      } else {
        usersLink?.classList.add('d-none');
        settingsLink?.classList.add('d-none');
      }

      // Populate profile info in sidebar
      const adminUserName = document.getElementById('admin-user-name');
      const adminUserRole = document.getElementById('admin-user-role');
      const adminAvatar = document.getElementById('admin-avatar');

      const fullName = profile?.full_name || session.user.user_metadata?.full_name || session.user.email || 'Admin';
      const userRole = role === 'super_admin' ? 'Super Admin' : 'Admin / Reseller';

      if (adminUserName) adminUserName.textContent = fullName;
      if (adminUserRole) adminUserRole.textContent = userRole;
      if (adminAvatar) {
        adminAvatar.textContent = fullName.charAt(0).toUpperCase();
        adminAvatar.className = `avatar text-white rounded-circle d-flex align-items-center justify-content-center fw-bold ${
          role === 'super_admin' ? 'bg-danger' : 'bg-primary'
        }`;
      }

      // Show the admin interface
      const body = document.getElementById('admin-body');
      if (body) {
        body.style.display = 'block';
      }

      // Set up logout handler
      const logoutBtn = document.getElementById('admin-logout-btn');
      logoutBtn?.addEventListener('click', async (e) => {
        e.preventDefault();
        await supabase.auth.signOut();
        window.location.href = '/admin/login';
      });
    }

    checkAdminAuth();
  </script>
</body>

</html>
